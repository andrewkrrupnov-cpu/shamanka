# Скопируй в .env и заполни значения. .env закоммичен НЕ будет (см. .gitignore).

# Telegram Bot API token (@BotFather)
BOT_TOKEN=

# OpenRouter API key (LLM)
OPENROUTER_API_KEY=

# Provider-token оплаты из @BotFather (ЮKassa). Пока пусто — оплата идёт
# звёздами Telegram (XTR). Заполни, чтобы включить оплату картой в рублях.
YOOKASSA_PROVIDER_TOKEN=

# Чеки 54-ФЗ: поставь 1, если в ЛК ЮKassa включена автоотправка чеков
# («Мой налог» или онлайн-касса). Тогда инвойс запросит email покупателя
# и передаст состав чека в ЮKassa. Без автоотправки чеков оставь пустым.
YOOKASSA_SEND_RECEIPT=

# PostgreSQL
POSTGRES_USER=shamanka
POSTGRES_PASSWORD=shamanka
POSTGRES_DB=shamanka
# Хост БД: "db" внутри docker-compose, "localhost" при локальном запуске
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Прокси для OpenRouter (если IP сервера заблокирован Cloudflare).
# С gluetun из docker-compose: http://gluetun:8888
OPENROUTER_PROXY=
