# Скопируй в .env и заполни значения. .env закоммичен НЕ будет (см. .gitignore).

# Telegram Bot API token (@BotFather)
BOT_TOKEN=

# OpenRouter API key (LLM)
OPENROUTER_API_KEY=

# Provider-token оплаты из @BotFather (ЮKassa). Пока пусто — бот показывает цены,
# но вместо инвойса выводит заглушку. Заполни, чтобы включить оплату картой.
YOOKASSA_PROVIDER_TOKEN=

# PostgreSQL
POSTGRES_USER=shamanka
POSTGRES_PASSWORD=shamanka
POSTGRES_DB=shamanka
# Хост БД: "db" внутри docker-compose, "localhost" при локальном запуске
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Прокси для OpenRouter (если IP сервера заблокирован Cloudflare).
# С gluetun из docker-compose: http://gluetun:8888
OPENROUTER_PROXY=
